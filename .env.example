# === Docker Compose deployment ===
# Only these two are needed — docker-compose.yml handles the rest.

# Database password (generate with: openssl rand -base64 24)
DB_PASSWORD=changeme

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-random-64-char-hex-string

# === Local development (without Docker) ===
# Uncomment these if running outside Docker:
# DATABASE_URL=postgresql://horizon:changeme@localhost:5432/horizon
# TZ=America/Toronto
# NODE_ENV=development
# LOG_LEVEL=debug
